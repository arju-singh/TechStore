# Copy to .env.local and fill in.
# If MONGODB_URI is left empty, the storefront renders from data/seed.ts
# (local sample catalog) so you can browse immediately without a database.

# Public site origin (no trailing slash). Used for canonical URLs, OpenGraph
# tags, the sitemap, robots.txt, and JSON-LD. Set to the real domain in
# production, e.g. https://techstore.example. Falls back to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Local MongoDB:   mongodb://127.0.0.1:27017/techstore
# MongoDB Atlas:   mongodb+srv://<user>:<pass>@<cluster>/techstore
MONGODB_URI=

# Secret used to sign session JWTs. REQUIRED for production — generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, a known insecure dev fallback is used (fine for local only).
AUTH_SECRET=

# Razorpay keys (Dashboard → Settings → API Keys). Use rzp_test_* keys for dev.
# KEY_ID is sent to the browser checkout; KEY_SECRET must stay server-side only.
# If unset, online payment is disabled and only Cash on Delivery is offered.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Comma-separated emails granted admin access to /admin. A signed-up user with
# a matching email is elevated to admin automatically (no DB change needed).
ADMIN_EMAILS=

# Marketplace: default platform commission (%) taken on each vendor's gross
# sales. A per-vendor override (set in /admin/stores) wins over this. Default 10.
PLATFORM_COMMISSION_RATE=10

# --- Wholesale (B2B) module ---
# The wholesale module is DB-only: with no MONGODB_URI its routes fail loudly
# ("requires a database") rather than serving fabricated data.

# Where wholesaler verification documents are stored on disk (real uploads).
# Default: .uploads/wholesale (gitignored). Must be writable.
WHOLESALE_UPLOAD_DIR=.uploads/wholesale

# Real email delivery for notifications (approvals, RFQ, orders). OPTIONAL —
# if unset, notifications are in-app only (never faked as "sent"). Uses the
# Resend HTTP API (no extra dependency).
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=

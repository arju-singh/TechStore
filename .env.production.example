# ─────────────────────────────────────────────────────────────────────────────
# TechStore — PRODUCTION environment (Vercel)
#
# Copy the NON-secret lines into a local .env.production for reference, and set
# EVERY variable in Vercel → Project → Settings → Environment Variables
# (Production scope). NEVER commit real values — this file holds names + notes
# only, and .env*.local / real secrets stay out of git.
#
# Legend:  [SECRET] server-only, never in the browser  ·  [PUBLIC] safe to ship
# to the client (only NEXT_PUBLIC_* reaches the browser).
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# [PUBLIC] The live origin (no trailing slash). Used for canonical/OG URLs,
# sitemap, robots, JSON-LD. Set to your Cloudflare-managed domain once live.
NEXT_PUBLIC_SITE_URL=            # e.g. https://techstore.example

# ── Database — MongoDB Atlas (free M0 tier) ──────────────────────────────────
# [SECRET] Atlas → Database → Connect → Drivers → connection string. Create a
# DB user (NOT your Atlas login), URL-encode the password, and add Vercel's
# egress to Network Access (or allow 0.0.0.0/0 for the free tier).
#   WHAT I NEED FROM YOU: the full mongodb+srv://... string with the db name.
MONGODB_URI=                     # mongodb+srv://<user>:<pass>@<cluster>/techstore

# ── Sessions (current custom-JWT auth, until Firebase Auth phase lands) ───────
# [SECRET] Sign the session JWT. Generate a strong one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   WHAT I NEED FROM YOU: nothing — generate it yourself and paste into Vercel.
AUTH_SECRET=

# [CONFIG] Comma-separated emails auto-elevated to admin (no secret).
ADMIN_EMAILS=                    # e.g. connect@akshaykotish.com
# [CONFIG] Platform commission % on vendor sales (default 10).
PLATFORM_COMMISSION_RATE=10

# ── Firebase Authentication ──────────────────────────────────────────────────
# Firebase Console → Project settings.
# Web config (General tab) — [PUBLIC], meant to ship to the browser:
#   WHAT I NEED FROM YOU: apiKey, authDomain, projectId, appId.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=      # <project-id>.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Admin SDK service account (Service accounts tab → Generate new private key) —
# [SECRET], verifies ID tokens server-side:
#   WHAT I NEED FROM YOU: client_email and private_key from the downloaded JSON.
#   (Keep the private key's \n newlines escaped as a single-line value.)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Images & media — Cloudinary ──────────────────────────────────────────────
# Cloudinary Dashboard → Product Environment Credentials.
#   WHAT I NEED FROM YOU: cloud name, API key, API secret.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=     # [PUBLIC] used to build delivery URLs
CLOUDINARY_API_KEY=                    # [SECRET] (server-side signing)
CLOUDINARY_API_SECRET=                 # [SECRET] signed uploads / admin API

# ── Payments — Razorpay (India) ──────────────────────────────────────────────
# Razorpay Dashboard → Settings → API Keys. Use LIVE keys for production.
#   WHAT I NEED FROM YOU: key_id (public) and key_secret (secret).
RAZORPAY_KEY_ID=                       # [PUBLIC] sent to the checkout widget
RAZORPAY_KEY_SECRET=                   # [SECRET] server-side signature verify

# ── Payments — Stripe (International) ─────────────────────────────────────────
# Stripe Dashboard → Developers → API keys (+ Webhooks for the signing secret).
#   WHAT I NEED FROM YOU: publishable key, secret key, and webhook signing secret.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # [PUBLIC] pk_live_...
STRIPE_SECRET_KEY=                     # [SECRET] sk_live_...
STRIPE_WEBHOOK_SECRET=                 # [SECRET] whsec_... (from the webhook endpoint)

# ── Email — Resend ───────────────────────────────────────────────────────────
# Resend Dashboard → API Keys; verify your sending domain (via Cloudflare DNS).
#   WHAT I NEED FROM YOU: the API key and a verified from-address.
RESEND_API_KEY=                        # [SECRET]
NOTIFICATION_FROM_EMAIL=               # e.g. TechStore <no-reply@techstore.example>
